<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title }}</title>
  <meta name="description" content="A 12-hour improv marathon by Improvlore — packed with shows and jams. Watch from the front row or jump in and play. 1st May 2026, Underline Center, Bangalore.">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Improvlore Marathon">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="A 12-hour improv marathon by Improvlore — packed with shows and jams. Watch from the front row or jump in and play. 1st May 2026, Underline Center, Bangalore.">
  <meta property="og:url" content="https://marathon.improvlore.com/">
  <meta property="og:image" content="https://marathon.improvlore.com/assets/poster-l.png">
  <meta property="og:image:width" content="1921">
  <meta property="og:image:height" content="1081">
  <meta property="og:image:alt" content="All Play No Work — 12-Hour Improv Marathon by Improvlore, 1st May 2026">

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="A 12-hour improv marathon by Improvlore — packed with shows and jams. Watch from the front row or jump in and play. 1st May 2026, Underline Center, Bangalore.">
  <meta name="twitter:image" content="https://marathon.improvlore.com/assets/poster-l.png">
  <meta name="twitter:image:alt" content="All Play No Work — 12-Hour Improv Marathon by Improvlore, 1st May 2026">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/assets/apnw-r.png">
  <link rel="apple-touch-icon" href="/assets/apnw-r.png">

  <link rel="stylesheet" href="/assets/events.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet">

</head>

<body>
   

</div>
  <main>
      {{ content | safe }}
  </main>



  <footer>
    <details class="social-fab">
      <summary class="social-fab-toggle" aria-label="Open social links">
        <img src="https://cdn.simpleicons.org/instagram/E4405F" alt="Instagram">
      </summary>
      <div class="social-fab-menu">
        <a class="social-icon" href="{{ social.whatsapp }}" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
          <img src="https://cdn.simpleicons.org/whatsapp/25D366" alt="WhatsApp">
        </a>
        <a class="social-icon" href="{{ social.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <img src="https://cdn.simpleicons.org/instagram/E4405F" alt="Instagram">
        </a>
        <a class="social-icon" href="{{ social.youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <img src="https://cdn.simpleicons.org/youtube/FF0000" alt="YouTube">
        </a>
        <a class="social-icon" href="{{ social.gmail }}" target="_blank" rel="noopener noreferrer" aria-label="Email">
          <img src="https://cdn.simpleicons.org/gmail/EA4335" alt="Email">
        </a>
      </div>
    </details>
  </footer>

   <script>
    window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>


</body>
</html>
