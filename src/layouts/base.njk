<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title }}</title>
  <meta name="description" content="An all-day improv festival by Improvlore — packed with shows and jams. Watch from the front row or jump in and play. 1st May 2026, Underline Center, Bangalore.">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Improvlore Marathon">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="An all-day improv festival by Improvlore — packed with shows and jams. Watch from the front row or jump in and play. 1st May 2026, Underline Center, Bangalore.">
  <meta property="og:url" content="https://marathon.improvlore.com/">
  <meta property="og:image" content="https://marathon.improvlore.com/assets/apnw-c.png">
  <meta property="og:image:alt" content="All Play No Work — All-Day Improv Festival by Improvlore, 1st May 2026">

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="An all-day improv festival by Improvlore — packed with shows and jams. Watch from the front row or jump in and play. 1st May 2026, Underline Center, Bangalore.">
  <meta name="twitter:image" content="https://marathon.improvlore.com/assets/apnw-c.png">
  <meta name="twitter:image:alt" content="All Play No Work — All-Day Improv Festival by Improvlore, 1st May 2026">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/assets/apnw-r.png">
  <link rel="apple-touch-icon" href="/assets/apnw-r.png">

  <link rel="stylesheet" href="/assets/events.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,900&display=swap" rel="stylesheet">

</head>

<body>

  <header class="site-header">
    <a class="site-header-brand" href="/">All Play No Work</a>
    <nav class="site-header-nav">
      <a href="/" class="site-header-link">Home</a>
      <a href="/events/" class="site-header-link site-header-link--cta">Schedule</a>
    </nav>
  </header>

  <main>
      {{ content | safe }}
  </main>



  <footer>
    <div class="social-fab-wrapper">
      <div class="social-fab-nudge" aria-hidden="true">Join our community</div>
      <a class="social-fab-toggle" aria-label="WhatsApp" id="social-fab-btn" href="{{ social.whatsapp }}" target="_blank" rel="noopener noreferrer">
        <img id="social-fab-icon" src="https://cdn.simpleicons.org/whatsapp/ffffff" alt="WhatsApp">
      </a>
    </div>
  </footer>
  <script>
  (function () {
    var platforms = [
      { href: "{{ social.whatsapp }}", icon: "https://cdn.simpleicons.org/whatsapp/ffffff", label: "WhatsApp" },
      { href: "{{ social.instagram }}", icon: "https://cdn.simpleicons.org/instagram/ffffff", label: "Instagram" }
    ];
    var current = 0;
    var btn = document.getElementById('social-fab-btn');
    var icon = document.getElementById('social-fab-icon');

    btn.addEventListener('click', function () {
      current = (current + 1) % platforms.length;
      var next = platforms[current];
      btn.href = next.href;
      icon.style.opacity = '0';
      setTimeout(function () {
        icon.src = next.icon;
        icon.alt = next.label;
        btn.setAttribute('aria-label', next.label);
        icon.style.opacity = '1';
      }, 150);
    });
  })();
  </script>

   <script>
    window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>


</body>
</html>
