---
layout: base.njk
title: All Play No Work – Schedule
---

<div class="events-root">
  <a class="back-link" href="/" aria-label="Back to landing page">← Back</a>
  <section class="site-part site-part-events" id="schedule">
    <section class="events-section-header">
      <p class="events-section-kicker">Schedule</p>
      <h1 class="events-section-title">Full Schedule</h1>
    </section>

    <div class="format-explainer">
      <div class="format-card">
        <p class="format-label">Show</p>
        <p class="format-desc">Improvisers on stage, scenes built live from your suggestions.</p>
      </div>
      <div class="format-vs" aria-hidden="true">V/S</div>
      <div class="format-card">
        <p class="format-label">Jam</p>
        <p class="format-desc">Floor open to all — come curious, leave having played.</p>
      </div>
    </div>

    <div class="timeline">

    {% for ev in events %}
    {% if ev.tags and "UC" in ev.tags %}

      {% set img = null %}
      {% if ev.thumbnails and ev.thumbnails.length %}
        {% set img = ev.thumbnails[0].url %}
      {% elif ev.image_url %}
        {% set img = ev.image_url %}
      {% endif %}

      <div class="timeline-item">

        {% if ev.time %}
        <div class="timeline-time">
          {{ ev.time }}
        </div>
        {% endif %}

        <div class="timeline-dot"></div>

        <div class="timeline-card">

          {% if img %}
          <div class="event-image">
            <a href="{{ ev.learn_more }}" target="_blank" rel="noopener noreferrer">
              <img src="{{ img }}" alt="{{ ev.title }}">
            </a>
          </div>
          {% endif %}

          {% if ev.format %}<span class="format-pill format-pill--{{ ev.format | lower }}">{{ ev.format }}</span>{% endif %}
          <h2 class="event-title">{{ ev.title }}</h2>
          {% set desc = ev.excerpt or ev.description %}
          {% set full = ev.first_para or desc %}
          {% if desc %}
          {% if full and full.length > desc.length %}
          <div class="event-excerpt-wrap">
            <p class="event-excerpt event-excerpt--expandable" data-short="{{ desc | escape }}" data-full="{{ full | escape }}">{{ desc }}</p>
            <button class="read-more-btn" aria-expanded="false" onclick="toggleExcerpt(this)">↓</button>
          </div>
          {% else %}
          <p class="event-excerpt">{{ desc }}</p>
          {% endif %}
          {% endif %}

          <div class="event-buttons">
            <a class="btn btn-primary" href="{{ ev.url }}" target="_blank" rel="noopener noreferrer">Buy Ticket{% if ev.price %} ({{ ev.price }}){% endif %}</a>
            <a class="btn btn-ghost" href="{{ ev.learn_more }}" target="_blank" rel="noopener noreferrer">Learn More</a>
          </div>

        </div>

      </div>

    {% endif %}
    {% endfor %}

    </div>
  </section>
</div>

<script>
function toggleExcerpt(btn) {
  var p = btn.previousElementSibling;
  var expanded = btn.getAttribute('aria-expanded') === 'true';
  if (expanded) {
    p.textContent = p.dataset.short;
    p.classList.remove('expanded');
    btn.textContent = '↓';
    btn.setAttribute('aria-expanded', 'false');
  } else {
    p.textContent = p.dataset.full;
    p.classList.add('expanded');
    btn.textContent = '↑';
    btn.setAttribute('aria-expanded', 'true');
  }
}
</script>
