---
layout: base.njk
title: All Play No Work – Improvlore Marathon
---

<div class="events-root">
  <section class="site-part site-part-intro">

    {# 1. EVENTS CAROUSEL #}
    <section class="carousel-section" aria-label="Event schedule preview">
      <div class="carousel-header">
        <div>
          <p class="section-kicker">Schedule</p>
          <h2 class="carousel-title">Event Schedule</h2>
        </div>
      </div>
      <div class="carousel-layout">

        <div class="carousel-track-wrapper">
          <div class="carousel-track" data-carousel>
            {% for ev in events %}
            {% if ev.tags and "UC" in ev.tags %}
            {% set img = null %}
            {% if ev.thumbnails and ev.thumbnails.length %}
              {% set img = ev.thumbnails[0].url %}
            {% elif ev.image_url %}
              {% set img = ev.image_url %}
            {% endif %}
            <article class="carousel-card">
              <div class="carousel-card-main">
                {% if img %}
                <div class="carousel-card-image">
                  <a href="{{ ev.learn_more }}" target="_blank" rel="noopener noreferrer">
                    <img src="{{ img }}" alt="{{ ev.title }}" loading="lazy">
                  </a>
                </div>
                {% endif %}
                <div class="carousel-card-text">
                  <h3 class="carousel-card-title">{{ ev.title }}</h3>
                  {% if ev.excerpt %}<p class="carousel-card-excerpt">{{ ev.excerpt }}</p>{% endif %}
                </div>
              </div>
              <div class="carousel-card-body">
                {% if ev.time %}<p class="carousel-card-time">{{ ev.time }}</p>{% endif %}
                <div class="event-pills">
                  {% if ev.format %}<span class="format-pill format-pill--{{ ev.format | lower }}">{{ ev.format }}</span>{% endif %}
                  {% if ev.badges %}{% for badge in ev.badges %}<span class="format-pill format-pill--badge">{{ badge }}</span>{% endfor %}{% endif %}
                </div>
                <div class="event-buttons">
                  <a class="btn btn-primary" href="{{ ev.url }}" target="_blank" rel="noopener noreferrer">Buy Ticket{% if ev.price %} ({{ ev.price }}){% endif %}</a>
                  <a class="btn btn-ghost" href="{{ ev.learn_more }}" target="_blank" rel="noopener noreferrer">Learn More</a>
                </div>
              </div>
            </article>
            {% endif %}
            {% endfor %}
          </div>
          <div class="carousel-controls">
            <button class="carousel-btn" data-carousel-prev aria-label="Previous event">&#8249;</button>
            <div class="carousel-dots" data-carousel-dots></div>
            <button class="carousel-btn" data-carousel-next aria-label="Next event">&#8250;</button>
          </div>
          <div class="carousel-mobile-pills" data-carousel-pills>
            {% for ev in events %}
            {% if ev.tags and "UC" in ev.tags %}
            <button class="carousel-mobile-pill" data-carousel-pill>{{ ev.title }}</button>
            {% endif %}
            {% endfor %}
          </div>
        </div>

        <aside class="carousel-sidebar">
          <p class="carousel-sidebar-title">All events</p>
          <ul class="carousel-sidebar-list">
            {% for ev in events %}
            {% if ev.tags and "UC" in ev.tags %}
            <li class="carousel-sidebar-item" data-carousel-sidebar-item>
              {% if ev.time %}<div class="carousel-sidebar-item-time">{{ ev.time }}</div>{% endif %}
              <div class="carousel-sidebar-item-name">{{ ev.title }}</div>
            </li>
            {% endif %}
            {% endfor %}
          </ul>
        </aside>

      </div>
      <div class="carousel-lineup-cta">
        <a class="btn btn-ghost" href="/events/">View full schedule &#8594;</a>
      </div>
    </section>

    {# 2. POSTER and MARATHON INFO — side by side on desktop #}
    <div class="poster-hero-split">

      <section class="feature-poster" aria-label="All Play No Work Poster">
        <img src="/assets/apnw-c.png" alt="All Play No Work event poster">
      </section>

      <section class="hero" aria-label="About the marathon">
        <p class="hero-kicker">1 May 2026 · Bangalore</p>
        <h1 class="hero-title">All Play No Work</h1>
        <p class="hero-subtitle">
          An all-day improv festival. Step away from everything that feels like work and into something playful.
        </p>
        <div class="hero-actions">
          <a class="btn btn-ghost" href="https://underline.center/t/all-play-no-work-12-hour-improv-marathon-by-improv-lore/764" target="_blank" rel="noopener noreferrer">Read details about the festival</a>
        </div>
      </section>

    </div>

    {# 3. NEW TO IMPROV + IMPROVLORE — combined #}
    <section class="about-improvlore" aria-label="About Improvlore and newcomers">
      <p class="about-copy">
        <strong>Improvlore</strong> is a Bangalore-based improv troupe — home to weekly jams, workshops, and unscripted shows.
      </p>
      <p class="newcomer-callout">
        Never watched improv before? You'll fit right in. Shows are audience-shaped; jams are open to anyone who wants to try.
      </p>
      <div class="about-links">
        <a href="{{ social.instagram }}" target="_blank" rel="noopener noreferrer">Follow us on Instagram</a>
        <a href="mailto:improvlore@gmail.com">Write to us</a>
      </div>
    </section>

    {# 4. VENUE + MAP #}
    <section class="venue-section" aria-label="Venue info">
      <div class="venue-info">
        <p class="section-kicker">Venue</p>
        <h2 class="venue-name">Underline Center</h2>
        <p class="venue-address">Indiranagar, Bangalore</p>
        <a class="btn btn-ghost venue-map-btn" href="https://maps.app.goo.gl/tCm13hsE2Dn1TxCG9" target="_blank" rel="noopener noreferrer">Open in Maps ↗</a>
        <a class="btn btn-ghost venue-map-btn" href="https://underline.center" target="_blank" rel="noopener noreferrer">Check out Underline Center ↗</a>
      </div>
      <div class="venue-map" id="venue-map">
        <button class="venue-map-load" id="venue-map-load" aria-label="Load map">
          <img src="https://underline.center/uploads/default/original/1X/fa3aa3aa7f1fa6a624fc878105340deb1881033e.png" alt="Underline Center" class="venue-map-preview">
          <span class="venue-map-load-label">📍 Tap to load map</span>
        </button>
      </div>
    </section>

  </section>
</div>

<script>
(function () {
  // Carousel
  var wrapper = document.querySelector('.carousel-track-wrapper');
  var track = document.querySelector('[data-carousel]');
  if (!wrapper || !track) return;

  var cards = Array.prototype.slice.call(track.querySelectorAll('.carousel-card'));
  var total = cards.length;
  if (!total) return;

  var dotsContainer = document.querySelector('[data-carousel-dots]');
  var prevBtn = document.querySelector('[data-carousel-prev]');
  var nextBtn = document.querySelector('[data-carousel-next]');
  var sidebarItems = Array.prototype.slice.call(document.querySelectorAll('[data-carousel-sidebar-item]'));
  var pillItems = Array.prototype.slice.call(document.querySelectorAll('[data-carousel-pill]'));

  var current = 0;
  var timer = null;
  var dots = [];
  var resizeTimer = null;

  function sizeCards() {
    var w = wrapper.offsetWidth;
    cards.forEach(function(card) { card.style.width = w + 'px'; });
  }
  sizeCards();
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      sizeCards();
      track.style.transition = 'none';
      track.style.transform = 'translateX(-' + (current * wrapper.offsetWidth) + 'px)';
      setTimeout(function() { track.style.transition = ''; }, 50);
    }, 100);
  });

  for (var i = 0; i < total; i++) {
    var dot = document.createElement('button');
    dot.className = 'carousel-dot';
    dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
    (function(idx) {
      dot.addEventListener('click', function() { goTo(idx); });
    })(i);
    if (dotsContainer) dotsContainer.appendChild(dot);
    dots.push(dot);
  }

  var navGroups = [dots, sidebarItems, pillItems];

  function setActive(idx) {
    navGroups.forEach(function(group) {
      group.forEach(function(el, i) { el.classList.toggle('active', i === idx); });
    });
  }

  setActive(0);

  function goTo(n) {
    current = ((n % total) + total) % total;
    track.style.transform = 'translateX(-' + (current * wrapper.offsetWidth) + 'px)';
    setActive(current);
    resetTimer();
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(function() { goTo(current + 1); }, 12000);
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });

  [sidebarItems, pillItems].forEach(function(group) {
    group.forEach(function(item, i) {
      item.addEventListener('click', function() { goTo(i); });
    });
  });

  wrapper.addEventListener('mouseenter', function() { clearInterval(timer); });
  wrapper.addEventListener('mouseleave', resetTimer);

  var touchStartX = 0;
  wrapper.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    clearInterval(timer);
  }, { passive: true });
  wrapper.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    resetTimer();
  }, { passive: true });

  resetTimer();

  // Lazy map
  var mapBtn = document.getElementById('venue-map-load');
  if (mapBtn) {
    mapBtn.addEventListener('click', function () {
      var mapEl = document.getElementById('venue-map');
      var iframe = document.createElement('iframe');
      iframe.src = 'https://maps.google.com/maps?q=Underline+Center,+Indiranagar,+Bangalore&t=&z=16&ie=UTF8&iwloc=&output=embed';
      iframe.title = 'Underline Center on Google Maps';
      iframe.setAttribute('referrerpolicy', 'no-referrer-when-downgrade');
      iframe.setAttribute('allowfullscreen', '');
      mapEl.innerHTML = '';
      mapEl.appendChild(iframe);
    });
  }
})();
</script>
